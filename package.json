{
  "name": "devportfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "new:writeup": "pwsh scripts/new-writeup.ps1",
    "new:post": "pwsh scripts/new-post.ps1",
    "publish": "git add . && git commit -m 'Update content' && git push",
    "draft:list": "grep -r 'draft: true' src/content/",
    "draft:publish": "find src/content -name '*.md' -exec sed -i 's/draft: true/draft: false/' {} +"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.1.11",
    "astro": "^6.3.7",
    "katex": "^0.17.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.11",
    "unist-util-visit": "^5.0.0"
  }
}
